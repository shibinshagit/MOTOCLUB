# Copy to .env for local development:
#   cp .env.example .env
#
# Local PostgreSQL (default dev setup)
DATABASE_URL=postgresql://YOUR_USER@localhost:5432/motoclub_accounting_dev
NEON_DATABASE_URL=postgresql://YOUR_USER@localhost:5432/motoclub_accounting_dev

# Remote Neon (keep in .env.neon — only for production deploys / refreshing local data)
# NEON_DATABASE_URL=postgresql://user:password@your-neon-host/neondb?sslmode=require

# Optional public app URL for share links (e.g. https://your-domain.com)
NEXT_PUBLIC_APP_URL=

# Platform admin login (seeded once when admins table is empty)
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change-me
ADMIN_SEED_NAME=Platform Admin
